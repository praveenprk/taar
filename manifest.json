{
  "manifest_version": 3,
  "homepage_url": "https://github.com/praveenprk/taar",
  "version_name": "2.1.0",
  "name": "Taar",
  "version": "2.1.0",
  "description": "One click. Strip prompt filler. Runs locally.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "64": "icon64.png",
    "128": "icon128.png"
}
}
