{
  "manifest_version": 3,
  "homepage_url": "https://github.com/praveenprk/taar",
  "version_name": "2.1.0",
  "name": "Taar",
  "version": "2.1.0",
  "description": "One click. Strip prompt filler. No AI, no server.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
